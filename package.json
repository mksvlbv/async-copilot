{
  "name": "async-copilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src scripts eslint.config.mjs --ext .ts,.tsx,.mjs",
    "typecheck": "tsc --noEmit",
    "db:init": "node scripts/db-init.mjs all",
    "db:migrate": "node scripts/db-init.mjs migrate",
    "db:seed": "node scripts/db-init.mjs seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:local": "cross-env BASE_URL=http://localhost:3000 playwright test",
    "test:responsive": "npm run build && playwright test -c playwright.responsive.config.ts",
    "test:responsive:smoke": "npm run build && playwright test -c playwright.responsive.config.ts --grep @smoke",
    "test:responsive:a11y": "npm run build && playwright test -c playwright.responsive.config.ts --grep @a11y",
    "test:visual": "npm run build && playwright test -c playwright.responsive.config.ts --grep @visual",
    "test:visual:update": "npm run build && playwright test -c playwright.responsive.config.ts --grep @visual --update-snapshots",
    "audit:perf": "lhci autorun --config=./lighthouserc.cjs",
    "audit:a11y:pa11y": "pa11y-ci",
    "audit:a11y:axe": "axe https://async-copilot.vercel.app/ https://async-copilot.vercel.app/app https://async-copilot.vercel.app/app/samples https://async-copilot.vercel.app/app/runs --tags wcag2a,wcag2aa",
    "audit:a11y": "npm run audit:a11y:pa11y && npm run audit:a11y:axe",
    "audit:links": "linkinator https://async-copilot.vercel.app --config=./.linkinatorrc.json",
    "audit:visual": "lost-pixel",
    "audit:visual:update": "lost-pixel update",
    "audit": "npm run audit:links && npm run audit:a11y && npm run audit:perf && npm run audit:visual"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.35",
    "@phosphor-icons/react": "^2.1.7",
    "@sentry/nextjs": "^10.49.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.0",
    "ai": "^6.0.168",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "next": "^15.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.3",
    "@axe-core/playwright": "^4.11.3",
    "@axe-core/react": "^4.11.3",
    "@eslint/eslintrc": "^3.2.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.49.1",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.11.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.4",
    "jest-axe": "^10.0.0",
    "linkinator": "^7.6.1",
    "lost-pixel": "^3.22.0",
    "pa11y-ci": "^4.1.0",
    "pg": "^8.13.1",
    "postcss": "8.5.13",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}

# Async Copilot - environment template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local - it is in .gitignore.

# Supabase - get these from:
# https://supabase.com/dashboard/project/_/settings/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Groq - free LLM inference (Llama 3.3 70B)
# Get your key at: https://console.groq.com/keys (no credit card needed)
# Without this key, the app falls back to synthetic (regex) triage.
GROQ_API_KEY=gsk_your_key_here

# Sentry - error tracking and observability (free tier: 5k events/month)
# Get your DSN at: https://sentry.io → Project Settings → Client Keys
# Leave blank to disable Sentry in local dev.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Slack webhook integration (optional)
# Default behavior is dry-run so the approval boundary can be demonstrated
# without sending a real message. Set SLACK_WEBHOOK_DRY_RUN=false only when
# you want to send a live Slack webhook after human approval.
SLACK_WEBHOOK_URL=
SLACK_WEBHOOK_DRY_RUN=true

# Google OAuth / Gmail import (optional)
# Narrow Milestone 4 slice: one shared inbox per workspace, manual thread import.
# Required only when you want to connect a real Gmail inbox.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override. If blank, the app derives the callback from the current origin.
GOOGLE_OAUTH_REDIRECT_URI=

# Database direct connection (for Supabase CLI migrations only, server-side)
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# Get from: Supabase Dashboard -> Project Settings -> Database -> Connection string
SUPABASE_DB_URL=
